{
    "notionSection": {
        "type": "section",
        "description": "Notion integration"
    },
    "notionToken": {
        "type": "entry",
        "default": "",
        "description": "Notion integration token (secret_...)",
        "tooltip": "Create an internal integration at notion.so/my-integrations, share your Projects database with it, and paste the token here. Stored in plaintext in the applet config."
    },
    "notionDatabaseId": {
        "type": "entry",
        "default": "99d9eb7831fd41e9b42f966ebd9b16cb",
        "description": "Projects database ID",
        "tooltip": "The 32-char id of your Notion Projects database."
    },
    "syncIntervalSec": {
        "type": "spinbutton",
        "default": 300,
        "min": 30,
        "max": 3600,
        "step": 30,
        "units": "seconds",
        "description": "Background sync interval"
    },
    "syncNow": {
        "type": "button",
        "description": "Sync from Notion now",
        "callback": "onSyncNowClicked"
    },
    "appearanceSection": {
        "type": "section",
        "description": "Appearance"
    },
    "panelIconSize": {
        "type": "spinbutton",
        "default": 22,
        "min": 12,
        "max": 48,
        "step": 1,
        "units": "px",
        "description": "Panel icon size"
    },
    "keybindingsSection": {
        "type": "section",
        "description": "Keyboard shortcuts"
    },
    "kbSchemeVersion": {
        "type": "generic",
        "default": 0
    },
    "kbWorkspacePrev": {
        "type": "keybinding",
        "default": "<Super>Left",
        "description": "Previous workspace (within project)"
    },
    "kbWorkspaceNext": {
        "type": "keybinding",
        "default": "<Super>Right",
        "description": "Next workspace (within project)"
    },
    "kbProjectPrev": {
        "type": "keybinding",
        "default": "<Super><Alt>Left",
        "description": "Previous project (list order)"
    },
    "kbProjectNext": {
        "type": "keybinding",
        "default": "<Super><Alt>Right",
        "description": "Next project (list order)"
    },
    "kbMoveWindowPrev": {
        "type": "keybinding",
        "default": "<Primary><Super>Left",
        "description": "Move window to previous workspace"
    },
    "kbMoveWindowNext": {
        "type": "keybinding",
        "default": "<Primary><Super>Right",
        "description": "Move window to next workspace"
    },
    "kbMoveWindowProjectPrev": {
        "type": "keybinding",
        "default": "<Primary><Super><Alt>Left",
        "description": "Move window to previous project (list order)"
    },
    "kbMoveWindowProjectNext": {
        "type": "keybinding",
        "default": "<Primary><Super><Alt>Right",
        "description": "Move window to next project (list order)"
    },
    "kbSwitcher": {
        "type": "keybinding",
        "default": "<Super>Tab",
        "description": "Project switcher (MRU)"
    },
    "kbOpenNotion": {
        "type": "keybinding",
        "default": "<Super>n",
        "description": "Open active project's Notion page"
    },
    "kbTogglePanel": {
        "type": "keybinding",
        "default": "<Super>p",
        "description": "Open the project toggle panel"
    },
    "wmSection": {
        "type": "section",
        "description": "Window management (Cinnamon actions, reassigned)"
    },
    "kbTileLeft": {
        "type": "keybinding",
        "default": "<Super><Shift>Left",
        "description": "Tile window left"
    },
    "kbTileRight": {
        "type": "keybinding",
        "default": "<Super><Shift>Right",
        "description": "Tile window right"
    },
    "kbTileUp": {
        "type": "keybinding",
        "default": "<Super><Shift>Up",
        "description": "Tile window up"
    },
    "kbTileDown": {
        "type": "keybinding",
        "default": "<Super><Shift>Down",
        "description": "Tile window down"
    },
    "kbMaximize": {
        "type": "keybinding",
        "default": "<Alt>a",
        "description": "Maximize window"
    },
    "kbMinimize": {
        "type": "keybinding",
        "default": "<Alt>s",
        "description": "Minimize window"
    }
}
