{
  "name": "better-workspaces-dev",
  "private": true,
  "description": "Dev harness for BetterWorkspaces (tests only — the applet itself runs under GJS/Cinnamon)",
  "scripts": {
    "test": "node --test tests/*.test.js",
    "lint": "eslint \"better-workspaces@pedrou2000/**/*.js\" \"tests/**/*.js\" eslint.config.js",
    "lint:fix": "eslint --fix \"better-workspaces@pedrou2000/**/*.js\" \"tests/**/*.js\" eslint.config.js",
    "format": "prettier --write \"better-workspaces@pedrou2000/**/*.js\" \"tests/**/*.js\" eslint.config.js",
    "check": "prettier --check \"better-workspaces@pedrou2000/**/*.js\" \"tests/**/*.js\" eslint.config.js && npm run lint && npm test"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.7.0",
    "prettier": "^3.9.4"
  }
}
